# --------- Dados ---------
# Dataset bruto (telco_churn.csv) e parquet limpo SÃO comitados.
# data/processed/ é gerado a cada execução, fica fora.
data/processed/*
!data/processed/.gitkeep

# --------- Modelos ---------
# Ignora tudo em models/ EXCETO o final.joblib (a API depende dele).
# Modelos intermediários (mlp.pt, baselines.joblib, etc) ficam fora.
models/*
!models/final.joblib
!models/.gitkeep

